# Product Scanner Mobile App Environment Configuration

# Backend API URL - Update this to match your backend service
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Auth0 Configuration (optional - for production)
EXPO_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=your-client-id
EXPO_PUBLIC_AUTH0_AUDIENCE=https://product-scanner.api

# Analytics and Monitoring (optional)
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
EXPO_PUBLIC_ANALYTICS_API_KEY=your-analytics-key